# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─────────────────────────────────────────────────────────────
#  ПОРТАТИВКА: всё тяжёлое и сгенерированное живёт ВНУТРИ папки
#  приложения (на несистемном диске) и в репозиторий НЕ попадает.
#  Пушим только исходники + .bat/.ps1 лаунчеры.
# ─────────────────────────────────────────────────────────────

# Портативный Python (embed + venv CUDA llama-cpp-python для текст-сервера)
/python/
/python-text/
/python-image/
/python311._pth
cuda_version.txt
*.venv/
.venv/

# Портативный Node.js runtime (скачивается лаунчером install.bat)
/node/

# Локальные модели и весь HF/torch кэш (GGUF Gemma 4, FLUX.2 SDNQ и пр.)
/models/
/cache/

# Временные файлы (TEMP/TMP перенаправлены сюда)
/temp/
/downloads/

# Результаты / сгенерированные изображения
/output/
/generated/
/public/generated
/public/uploads

# Встроенные клоны бэкендов (image-воркер + TTS-движок) — install.bat клонит внутрь
/ultra-fast-image-gen/
/shorts-dub/

# Сессионные артефакты ассистента / тестовые логи
/.claude/
/stub.log

# ─────────────────────────────────────────────────────────────
#  Node / Next.js
# ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# сборка / упаковка
/build
/dist

# ─────────────────────────────────────────────────────────────
#  Локальные данные приложения (SQLite-база чатов и т.п.)
# ─────────────────────────────────────────────────────────────
/data
/.serena

# тесты
/coverage

# ─────────────────────────────────────────────────────────────
#  Python артефакты
# ─────────────────────────────────────────────────────────────
__pycache__/
*.pyc

# ─────────────────────────────────────────────────────────────
#  Логи / прочее
# ─────────────────────────────────────────────────────────────
/logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.DS_Store
*.pem

# env-файлы (можно опт-ин закоммитить при необходимости)
.env*
!.env.example

# vercel
.vercel
