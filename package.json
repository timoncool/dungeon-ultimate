{
  "name": "open-dungeon",
  "version": "0.3.3",
  "private": true,
  "description": "Fully on-device AI roleplay app with local text and inline image generation",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "dev:tailscale": "next dev -H 0.0.0.0 -p 3002",
    "build": "next build",
    "start": "next start",
    "start:tailscale": "next start -H 0.0.0.0 -p 3002",
    "lint": "eslint",
    "check:windows-launchers": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\check-windows-launchers.ps1",
    "check:image-routing": "node scripts/run-python.mjs scripts/check-image-server-routing.py",
    "check:image-server-http": "node scripts/run-python.mjs scripts/check-image-server-http.py",
    "windows:diagnose": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\diagnose-windows.ps1 -IncludeLogTails",
    "windows:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\stop-windows.ps1",
    "image:loop:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\run-windows-image-loop.ps1 -Device both -Count 1 -DiagnoseOnSuccess",
    "image:smoke:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\smoke-windows-image.ps1",
    "image:smoke:windows:cuda": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\smoke-windows-image.ps1 -Device cuda",
    "image:smoke:windows:cpu": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\smoke-windows-image.ps1 -CpuOnly",
    "image:server": "node scripts/start-image-server.mjs",
    "image:warm:mflux": "curl -sS -X POST http://127.0.0.1:7869/warm -H 'Content-Type: application/json' -d '{\"backend\":\"mflux-hs\"}'",
    "image:warm:sdnq": "curl -sS -X POST http://127.0.0.1:7869/warm -H 'Content-Type: application/json' -d '{\"backend\":\"sdnq-hs\"}'",
    "image:codex": "node scripts/codex-imagegen.mjs",
    "flux:worker": "npm run image:server"
  },
  "dependencies": {
    "@3d-dice/dice-box-threejs": "^0.0.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.16",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
