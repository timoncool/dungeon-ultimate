{
  "name": "open-dungeon",
  "version": "0.3.1",
  "private": true,
  "description": "Fully on-device AI roleplay app with local text and inline image generation",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "dev:tailscale": "next dev -H 0.0.0.0 -p 3002",
    "build": "next build",
    "start": "next start",
    "start:tailscale": "next start -H 0.0.0.0 -p 3002",
    "lint": "eslint",
    "image:server": "\"${ULTRA_FAST_IMAGE_GEN_PYTHON:-$HOME/ultra-fast-image-gen/.venv/bin/python}\" image_server/optimized_image_server.py",
    "image:warm:mflux": "curl -sS -X POST http://127.0.0.1:7869/warm -H 'Content-Type: application/json' -d '{\"backend\":\"mflux-hs\"}'",
    "image:warm:sdnq": "curl -sS -X POST http://127.0.0.1:7869/warm -H 'Content-Type: application/json' -d '{\"backend\":\"sdnq-hs\"}'",
    "image:codex": "node scripts/codex-imagegen.mjs",
    "flux:worker": "npm run image:server"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.16",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
