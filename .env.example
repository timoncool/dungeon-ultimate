# Copy to .env.local (or .env.server) and fill in what you use.
# Everything is optional — the app runs fully local with no keys at all.

# --- Text generation defaults ---
# local = Ollama, custom = "Connect a server" / OpenAI-compatible.
DEFAULT_TEXT_PROVIDER=local
LOCAL_TEXT_MODEL=gemma4:12b-it-qat

# --- Text generation: "Connect a server" provider (all optional) ---
# The Mac launchers can fill these in, or you can enter URL/model in-app.
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=
# For OpenRouter URLs:
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash
# For any other OpenAI-compatible server that needs a key:
OPENAI_COMPAT_API_KEY=
# Max output tokens per remote turn, plus OpenRouter attribution headers:
OPENROUTER_MAX_TOKENS=16384
OPENROUTER_APP_TITLE=Open Dungeon
OPENROUTER_APP_URL=http://localhost:3000

# --- Text generation: local via Ollama (the default provider) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
LOCAL_TEXT_MAX_TOKENS=4096
# Context window for local turns. Unset = the model's full native window
# (128K-256K). Set a lower cap to bound prefill time on very long stories.
LOCAL_TEXT_CONTEXT=

# --- Image generation (optional, needs ultra-fast-image-gen) ---
FLUX_WORKER_URL=http://127.0.0.1:7869
ULTRA_FAST_IMAGE_GEN_DIR=~/ultra-fast-image-gen
# macOS/Linux: ~/ultra-fast-image-gen/.venv/bin/python
# Windows: %USERPROFILE%\ultra-fast-image-gen\.venv\Scripts\python.exe
ULTRA_FAST_IMAGE_GEN_PYTHON=
IMAGE_SERVER_DEVICE=auto
IMAGE_SERVER_DEFAULT_BACKEND=
# Patched MFLUX checkout (made by ultra-fast-image-gen/scripts/setup_mflux_hs.sh).
# Defaults to ~/.cache/ultra-fast-image-gen/mflux — usually leave unset.
MFLUX_DIR=

# --- Storage ---
SQLITE_DB_PATH=

# --- Dev server access from other devices (e.g. phone over Tailscale) ---
# Comma-separated extra hostnames/IPs allowed to reach `next dev`.
ALLOWED_DEV_ORIGINS=
